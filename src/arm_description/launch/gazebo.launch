<launch>
  <param name="robot_description" command="$(find xacro)/xacro $(find arm_description)/urdf/arm_urdf.urdf.xacro"/>
  
  <node name="gazebo" pkg="gazebo_ros" type="gazebo" args="-s libgazebo_ros_factory.so"/>

  <node name="spawn_urdf" pkg="gazebo_ros" type="spawn_model"
        args="-param robot_description -urdf -model my_robot" />
</launch>
